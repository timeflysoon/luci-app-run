{
	"luci-app-run": {
		"description": "Grant access to upload and execute .run, .sh, .ipk and .apk files",
		"read": {
			"ubus": {
				"luci-app-run": [ "status", "read_log" ]
			}
		},
		"write": {
			"ubus": {
				"luci-app-run": [
					"upload_start",
					"upload_chunk",
					"upload_finish",
					"run",
					"download_run",
					"cleanup"
				]
			}
		}
	}
}
